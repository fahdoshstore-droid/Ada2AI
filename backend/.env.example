# Ada2AI Backend - Environment Variables
# Copy to .env and fill in values

# ===========================================
# AI API Keys (Required for Vision Analysis)
# ===========================================

# Option 1: Anthropic Claude (Recommended for Scout Reports)
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Google Gemini (Free tier available)
# GEMINI_API_KEY=AIza...

# Option 3: OpenAI GPT-4o Vision
# OPENAI_API_KEY=sk-...

# ===========================================
# GPU Support
# ===========================================

# Set to 'true' if running on GPU machine
CUDA_ENABLED=false

# ===========================================
# Redis Queue
# ===========================================

REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ===========================================
# Security
# ===========================================

# Redis Commander password (for monitoring)
REDIS_PASSWORD=admin123

# JWT Secret for authentication
JWT_SECRET=change-this-in-production

# ===========================================
# CORS (Origins allowed)
# ===========================================

ALLOWED_ORIGINS=http://localhost:3000,https://www.ada2ai.com

# ===========================================
# File Upload Limits
# ===========================================

MAX_FILE_SIZE_MB=500
MAX_UPLOAD_TIME_SECONDS=600
