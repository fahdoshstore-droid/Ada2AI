# Ada2AI Environment Variables Template
# Copy this to .env and fill in your values

# Database (local)
DATABASE_URL=file:./local.db

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=***

# Supabase Configuration (client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Auth (server-side — required for API authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Anthropic API Key (server-side ONLY — never expose to client)
ANTHROPIC_API_KEY=***

# VideoDB API Key (for Agentic Streams — web-research video generation)
# Get a free key at https://console.videodb.io
VIDEO_DB_API_KEY=your-videodb-key

# Google API Key (for Agentic Video Editor — Gemini ADK + FFmpeg/MoviePy)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# Manus OAuth
MANUS_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://auth.manus.ai

# Python Backend CORS (optional — defaults to localhost:3000)
# CORS_ORIGIN=https://your-production-domain.com

# Google Maps (optional)
# VITE_GOOGLE_MAPS_KEY=your-maps-api-key

# Port (optional — defaults to 3000)
# PORT=3000
