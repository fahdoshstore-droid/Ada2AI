{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "builds": [
    {
      "src": "server/_core/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/scout/(.*)",
      "dest": "/server/_core/index.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server/_core/index.ts"
    }
  ]
}
