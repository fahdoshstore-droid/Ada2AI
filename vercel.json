{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "server/_core/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/scout/(.*)",
      "dest": "/server/_core/index.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server/_core/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
